# Non-secret settings for usbutler
LOG_LEVEL=INFO
USBUTLER_USERS_DB=/app/data/users.json
USBUTLER_WEB_ENABLE_READER=1
USBUTLER_DOOR_GPIO=8
USBUTLER_DOOR_ACTIVE_HIGH=0
USBUTLER_GPIO_CHIP=/dev/gpiochip0
USBUTLER_DOOR_REOPEN_DELAY=5

# LED wall settings
USBUTLER_LED_ENDPOINT=http://ledka.lo.f0rth.space/text
USBUTLER_LED_FONT=BMplain
USBUTLER_LED_TIMEOUT=500
USBUTLER_LED_POSITION_X=10
USBUTLER_LED_POSITION_Y=5

# Telegram (non-secret defaults)
USBUTLER_TG_MESSAGE_TEMPLATE=Door unlocked at {time} by {name} [{identifier_type}: {identifier}]
USBUTLER_TG_REQUEST_TIMEOUT=5
